# Supabase (email/password, v.v.)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
#
# Bìa trên Storage: bật Image Transformations (Dashboard → Storage → Settings) để URL /render/image/... nhỏ hơn (Pro+ trên Supabase hosted).
#
# Ảnh bìa ngoài Supabase: mặc định dùng images.weserv.nl → WebP nhỏ. Tắt: VITE_COVER_IMAGE_PROXY=off
# VITE_COVER_IMAGE_PROXY=off

# Optional: used in signup / resend confirmation email links (must match Authentication → URL Configuration)
# VITE_SITE_URL=https://mitruyen.me
#
# Google đăng nhập (OAuth): Supabase Dashboard → Authentication → Providers → Google (Client ID + Secret từ Google Cloud Console).
# Trong Google Cloud → OAuth client → Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
# Trong Supabase → URL Configuration → Redirect URLs: thêm Site URL + http://localhost:5173/ (dev).

# Google AdSense — lấy trong https://www.google.com/adsense/
# Client dạng ca-pub-xxxxxxxxxxxxxxxx (đã gắn trong index.html + fallback code)
VITE_ADSENSE_CLIENT=ca-pub-6602775323692698

# Một ad unit (slot) dùng chung — mitruyen trial 1 (fallback trong adsConfig nếu để trống)
VITE_ADSENSE_SLOT_DEFAULT=8426876857

# Tuỳ chọn: tách slot theo trang (cùng client)
# VITE_ADSENSE_SLOT_HOME=
# VITE_ADSENSE_SLOT_DETAIL=
# VITE_ADSENSE_SLOT_CHAPTER_TOP=
# VITE_ADSENSE_SLOT_CHAPTER_BOTTOM=
