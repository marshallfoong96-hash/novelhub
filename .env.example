# Supabase (email/password, v.v.)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
#
# Bìa trên Storage: bật Image Transformations (Dashboard → Storage → Settings) để URL /render/image/... nhỏ hơn (Pro+ trên Supabase hosted).
#
# Ảnh bìa ngoài Supabase: mặc định dùng images.weserv.nl → WebP nhỏ. Tắt: VITE_COVER_IMAGE_PROXY=off
# VITE_COVER_IMAGE_PROXY=off

# Optional: used in signup / resend confirmation email links (must match Authentication → URL Configuration)
# VITE_SITE_URL=https://mitruyen.me
#
# --- Static prerender (novel intro only, post-build → dist/truyen/<id>/index.html) ---
# PRERENDER_SKIP=1                    # skip prerender step entirely
# PRERENDER_NOVEL_IDS=12,34,56        # explicit novel ids (takes precedence over LIMIT)
# PRERENDER_NOVEL_LIMIT=30            # else: top N by view_count (requires VITE_SUPABASE_* in .env)
# SITE_ORIGIN=https://mitruyen.me     # canonical / og:url (defaults to mitruyen.me if unset)
#
# --- Cloudflare R2 CDN (covers off Supabase Storage) — see R2-CDN-SETUP.md ---
# Hostname(s) of your public R2 URL (comma-separated) — listCoverUrl uses direct URL (WebP), no weserv.
# Example (your R2 public URL):
# VITE_CDN_COVER_HOSTS=pub-ce7c60cfbf86416ea5021d2e69486cd1.r2.dev
# Or prefix match (same as VITE_PUBLIC_ASSETS_BASE — use full https URL, not //...):
# VITE_CDN_COVER_BASE=https://pub-ce7c60cfbf86416ea5021d2e69486cd1.r2.dev
# VITE_PUBLIC_ASSETS_BASE=https://pub-ce7c60cfbf86416ea5021d2e69486cd1.r2.dev
# Enable upload UI + POST /api/upload-cover (Pages Function + R2 binding COVERS):
# VITE_CDN_UPLOAD_ENABLED=true
#
# Pages Function secrets (Cloudflare Dashboard → Pages → Settings → Variables), not VITE_:
# PUBLIC_ASSETS_BASE=https://pub-ce7c60cfbf86416ea5021d2e69486cd1.r2.dev
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...   (same as VITE_SUPABASE_ANON_KEY)
#
# Vercel Serverless (api/upload-cover.js) — same POST /api/upload-cover; use S3 API + env vars:
# R2_ACCOUNT_ID=<Cloudflare account id>
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=mitruyen-covers
# PUBLIC_ASSETS_BASE=https://pub-ce7c60cfbf86416ea5021d2e69486cd1.r2.dev
# SUPABASE_URL= + SUPABASE_ANON_KEY= (same as above)
#
# One-off migration from Supabase Storage → R2 (local: npm run migrate:covers-r2; never commit service key):
# Reuse the same names as Vercel, or MIGRATE_* overrides:
# R2_ACCOUNT_ID=  R2_ACCESS_KEY_ID=  R2_SECRET_ACCESS_KEY=  R2_BUCKET_NAME=
# MIGRATE_R2_PUBLIC_BASE=  (or PUBLIC_ASSETS_BASE / VITE_PUBLIC_ASSETS_BASE)
# VITE_SUPABASE_URL=   MIGRATE_SUPABASE_SERVICE_ROLE=   (recommended for UPDATE novels)
# MIGRATE_DRY_RUN=1
#
# Google đăng nhập (OAuth): Supabase Dashboard → Authentication → Providers → Google (Client ID + Secret từ Google Cloud Console).
# Trong Google Cloud → OAuth client → Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
# Trong Supabase → URL Configuration → Redirect URLs: thêm Site URL + http://localhost:5173/ (dev).

# Google AdSense — lấy trong https://www.google.com/adsense/
# Client dạng ca-pub-xxxxxxxxxxxxxxxx (đã gắn trong index.html + fallback code)
VITE_ADSENSE_CLIENT=ca-pub-6602775323692698

# Một ad unit (slot) dùng chung — mitruyen trial 1 (fallback trong adsConfig nếu để trống)
VITE_ADSENSE_SLOT_DEFAULT=8426876857

# Tuỳ chọn: tách slot theo trang (cùng client)
# VITE_ADSENSE_SLOT_HOME=
# VITE_ADSENSE_SLOT_DETAIL=
# VITE_ADSENSE_SLOT_CHAPTER_TOP=
# VITE_ADSENSE_SLOT_CHAPTER_BOTTOM=
