# Supabase (bắt buộc cho đăng nhập Google)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
#
# Trong Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: http://localhost:3000 (dev) hoặc https://mitruyen.me (prod)
# - Redirect URLs: thêm http://localhost:3000/** và https://mitruyen.me/**
# (phải khớp cổng dev: `npm run dev` dùng port 3000 — xem vite.config.js)

# Google AdSense — lấy trong https://www.google.com/adsense/
# Client dạng ca-pub-xxxxxxxxxxxxxxxx (đã gắn trong index.html + fallback code)
VITE_ADSENSE_CLIENT=ca-pub-6602775323692698

# Một ad unit (slot) dùng chung — mitruyen trial 1 (fallback trong adsConfig nếu để trống)
VITE_ADSENSE_SLOT_DEFAULT=8426876857

# Tuỳ chọn: tách slot theo trang (cùng client)
# VITE_ADSENSE_SLOT_HOME=
# VITE_ADSENSE_SLOT_DETAIL=
# VITE_ADSENSE_SLOT_CHAPTER_TOP=
# VITE_ADSENSE_SLOT_CHAPTER_BOTTOM=
